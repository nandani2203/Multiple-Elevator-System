{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build elevator system",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-g",

                "-Iinclude",

                "src/elevator.cpp",
                "src/elevator_system.cpp",
                "src/simulator.cpp",
                "main.cpp",

                "-o",
                "elevator_sim.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}